# Copy to .env and edit. Defaults run a safe local paper-trading simulation.

# ---- Data source -------------------------------------------------------
# paper = synthetic local order books (default). live = real Polymarket APIs.
PM_DATA_MODE=paper
PM_CLOB_REST_URL=https://clob.polymarket.com
PM_GAMMA_URL=https://gamma-api.polymarket.com
PM_CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# ---- Execution (DANGER) ------------------------------------------------
# paper = simulated fills (default). live = place REAL orders.
# Live requires execution_mode=live AND api key AND wallet key, and you must
# still wire up py-clob-client in backend/execution.py. Leave as paper unless
# you fully understand the risk.
PM_EXECUTION_MODE=paper
PM_API_KEY=
PM_API_SECRET=
PM_API_PASSPHRASE=
PM_WALLET_PRIVATE_KEY=

# ---- Strategy ----------------------------------------------------------
PM_BANKROLL=10000
PM_MIN_PROFIT=0.05
# Which venue to run when not in cross-venue mode: polymarket | kalshi.
PM_VENUE=polymarket
# Faster-trader competition: fraction of arbs sniped before your order lands
# (0 = you win every race — unrealistic; 0.6 default ≈ realistic; 1 = brutal).
PM_COMPETITION=0.6
PM_MAX_DEPTH_FRAC=0.50
PM_KELLY_FRACTION=0.50
PM_FEE_BPS=0
PM_SCAN_INTERVAL=2.0
# Demo only: chance (0..1) a leg fails to fill, to watch the unwind safety net.
PM_SIMULATE_PARTIAL=0

# ---- Market-making mode (Kalshi liquidity rewards) ---------------------
# Quote both sides near the mid to earn maker rewards + the spread, instead of
# hunting arbitrage. The realistic, non-latency-racing edge on Kalshi.
PM_MARKET_MAKING=0
PM_MM_SPREAD=0.02          # half-spread (dollars) around the mid
PM_MM_SIZE=100            # shares quoted per side
PM_MM_MAX_INVENTORY=500   # cap net position per market (inventory risk limit)
PM_MM_REWARD_RATE=0.0002  # simulated reward per share quoted per tick
PM_MM_FILL_PROB=0.15      # demo: chance a quoted side gets hit per tick

# ---- Execution-risk forecasting (TimesFM) ------------------------------
# Predict whether a spread stays open long enough to fill both legs, and skip
# arbs likely to vanish. Heuristic by default; PM_USE_TIMESFM=1 uses Google's
# TimesFM 2.5 (needs `pip install timesfm`). NOT used to predict outcomes.
PM_USE_TIMESFM=0
PM_FORECAST_HORIZON=6
PM_MIN_FILL_SCORE=0       # 0 = don't filter; e.g. 0.5 = only attempt likely-to-fill arbs

# ---- Cross-venue (Kalshi) ----------------------------------------------
# Also pull Kalshi and detect cross-venue arbs (same event priced differently
# on Polymarket vs Kalshi). Kalshi is the U.S.-regulated venue. In paper mode
# this is simulated; in live mode it reads the public Kalshi API (read-only).
PM_CROSS_VENUE=0
PM_KALSHI_URL=https://api.elections.kalshi.com/trade-api/v2
# Kalshi trading credentials (only needed for LIVE cross-venue/Kalshi orders).
# API key id + RSA private key (PEM string, or a path to the .pem file).
# Requires `pip install cryptography`. Leave blank for demo/paper.
PM_KALSHI_API_KEY_ID=
PM_KALSHI_PRIVATE_KEY=

# ---- Telegram alerts (optional) ----------------------------------------
# Leave blank to disable. Create a bot with @BotFather to get the token, then
# message your bot once and read your chat id (see SETUP_LIVE.md).
PM_TELEGRAM_BOT_TOKEN=
PM_TELEGRAM_CHAT_ID=
PM_TELEGRAM_MIN_NOTIFY=1.0   # only alert on fills with |profit| >= this

# ---- Cloud dashboard sync (optional, Vercel) ---------------------------
# Push live state to the hosted dashboard so it's viewable anywhere. Point at
# your Vercel /api/ingest URL and a shared secret you also set in Vercel as the
# INGEST_TOKEN env var. Leave blank to keep everything local. No wallet key is
# ever sent — only the public snapshot (PnL, opportunities, trades).
PM_CLOUD_INGEST_URL=
PM_CLOUD_INGEST_TOKEN=
PM_CLOUD_SYNC_INTERVAL=5.0
